# Optional: override the server-side data file path used for owner auth,
# provider API keys, Ollama settings, saved chat history, and proxy settings.
LLMGPS_DATA_FILE=.llmgps-data.sqlite

# Optional: provide your own encryption secret directly.
# LLMGPS_DATA_KEY=

# Optional: load the encryption secret from a file, useful for Docker secrets
# or other mounted secret files.
# LLMGPS_DATA_KEY_FILE=

NEXT_PUBLIC_APP_NAME=llmgps